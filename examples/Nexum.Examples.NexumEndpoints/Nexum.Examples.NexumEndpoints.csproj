<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <!-- Enable Tier 3 interceptors generated by Nexum.SourceGenerators -->
    <InterceptorsNamespaces>$(InterceptorsNamespaces);Nexum.Examples.NexumEndpoints.Generated</InterceptorsNamespaces>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../../src/Nexum.Abstractions/Nexum.Abstractions.csproj" />
    <ProjectReference Include="../../src/Nexum/Nexum.csproj" />
    <ProjectReference Include="../../src/Nexum.Extensions.DependencyInjection/Nexum.Extensions.DependencyInjection.csproj" />
    <ProjectReference Include="../../src/Nexum.Extensions.AspNetCore/Nexum.Extensions.AspNetCore.csproj" />
    <ProjectReference Include="../../src/Nexum.Results/Nexum.Results.csproj" />
    <ProjectReference Include="../../src/Nexum.SourceGenerators/Nexum.SourceGenerators.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
  </ItemGroup>
</Project>
